# LudoHealt - copia questo file in `.env` e compila i valori.
#   cp .env.example .env

# Indirizzo BLE del braccialetto.
# Su macOS e' lo UUID CoreBluetooth (specifico del tuo Mac), non un MAC hardware.
# Lo trovi con un BLE scanner o nei log alla prima connessione.
BAND_ADDRESS=

# Database MySQL/MariaDB locale
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ludohealt
DB_USER=root
DB_PASS=

# OpenRouter - analisi AI dei dati di salute (chiave: https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Modello da usare per l'analisi
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
